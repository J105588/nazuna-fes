# ==============================================================================
# 2026年度 なずな祭公式サイト「百輝夜行」 環境変数設定サンプル (.env.example)
# ==============================================================================
# 使い方：このファイルを「.env」または「.env.local」にコピーし、Supabaseの値を入力してください。
# ※「VITE_USE_REAL_API=false」のままでも完全なモックデータとポスター演出で即時動作します。

# 1. Supabase API 設定 URL と Key (設定場所: Supabase Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-or-public-jwt-key"

# 2. 実API接続フラグ (trueに設定すると Supabase / GAS サーバーからリアルタイムフェッチを行います)
VITE_USE_REAL_API="false"

# 3. 外部連携 URL
VITE_GAS_PYRAMID_API="https://script.google.com/macros/s/your-gas-id/exec"
VITE_EXTERNAL_MAP_URL="https://map.nazuna.jp/campus"
VITE_INVENTORY_API="https://inventory.nazuna.jp/api"
